<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <section class="page-hero">
    <span class="kicker">Strumenti</span>
    <h1><%- ct('strumenti.hero_title') %></h1>
    <p class="lede"><%- ct('strumenti.hero_body') %></p>
    <p style="font-size:13px;color:var(--color-neutral-600);margin-top:14px">ⓘ <%- ct('strumenti.lang_note') %></p>
  </section>

  <section style="padding:14px 0 70px">
    <div class="svc-grid">
      <% for (const t of tools) { %>
      <a class="svc-card" href="<%= t.url %>" target="_blank" rel="noopener" data-track="tool_click" data-track-meta="<%= t.name %>">
        <span class="card-kicker">hvac.geopro.cc ↗</span>
        <h4><%= t.name %></h4>
        <p><%= t.description %></p>
      </a>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>
</div>
<%- include('partials/tail') %>
