<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <section class="page-hero">
    <span class="kicker">Referenze</span>
    <h1><%- ct('referenze.hero_title') %></h1>
    <p class="lede"><%- ct('referenze.hero_body') %></p>
  </section>

  <section style="padding:14px 0 70px">
    <% if (cases.length === 0) { %>
    <div class="card" style="align-items:flex-start;padding:42px 28px;background:var(--color-neutral-100)">
      <p style="margin:0;font-size:15px;color:var(--color-neutral-700)"><%- ct('referenze.empty_note') %></p>
    </div>
    <% } else { %>
    <div>
      <% for (const c of cases) { %>
      <div class="row-case">
        <div>
          <span class="card-kicker"><%= c.org %></span>
          <h3 style="font-size:21px;margin:8px 0 6px"><%= c.title %></h3>
          <p style="margin:0;font-size:14px;color:var(--color-neutral-700)"><%= c.description %></p>
        </div>
        <div></div>
        <div style="text-align:right">
          <p style="font-family:'Archivo';font-weight:700;font-size:30px;color:var(--color-accent);margin:0"><%= c.metric_value %></p>
          <p style="font-size:12px;color:var(--color-neutral-600);margin:4px 0 0;max-width:140px"><%= c.metric_label %></p>
        </div>
      </div>
      <% } %>
    </div>
    <div style="margin-top:36px">
      <a class="btn btn-primary" href="<%= link('/consulenza') %>" style="text-decoration:none"><%= (typeof locale !== 'undefined' && locale === 'en') ? 'Request a free site survey →' : 'Richiedi un sopralluogo gratuito →' %></a>
    </div>
    <% } %>
  </section>

  <%- include('partials/footer') %>
</div>
<%- include('partials/tail') %>
