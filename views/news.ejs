<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <section class="page-hero">
    <span class="kicker">News</span>
    <h1><%- ct('news.hero_title') %></h1>
    <p class="lede"><%- ct('news.hero_body') %></p>
  </section>

  <section style="padding:14px 0 70px">
    <% if (posts.length === 0) { %>
    <div class="card" style="align-items:flex-start;padding:42px 28px;background:var(--color-neutral-100)">
      <p style="margin:0;font-size:15px;color:var(--color-neutral-700)"><%- ct('news.empty_note') %></p>
    </div>
    <% } else { %>
    <div class="grid-cards3">
      <% for (const p of posts) { %>
      <a href="<%= link('/news') %>/<%= p.slug %>" class="card" style="text-decoration:none;color:inherit;padding:22px;background:#fff">
        <span class="card-kicker" style="font-feature-settings:'tnum' 1"><%= fmtDate(p.published_at) %> · <%= p.category %></span>
        <span class="card-title" style="font-size:19px"><%= p.title %></span>
        <span class="card-body"><%= p.excerpt %></span>
        <span class="card-meta"><%= p.read_minutes %> min</span>
      </a>
      <% } %>
    </div>
    <% } %>
  </section>

  <%- include('partials/footer') %>
</div>
<%- include('partials/tail') %>
