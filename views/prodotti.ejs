<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <section class="page-hero">
    <span class="kicker">Prodotti</span>
    <h1><%- ct('prodotti.hero_title') %></h1>
    <p class="lede"><%- ct('prodotti.hero_body') %></p>
  </section>

  <% const EN = (typeof locale !== 'undefined' && locale === 'en'); %>
  <% const groups = [
    ['heatpump', 'pompe-di-calore', 'prodotti.hp_title', 'prodotti.hp_body', 'var(--color-accent-2-500)', 'var(--color-accent-2-100)', 'var(--color-accent-2-800)'],
    ['ac', 'climatizzatori', 'prodotti.ac_title', 'prodotti.ac_body', 'var(--color-cool-500)', 'var(--color-cool-100)', 'var(--color-cool-800)'],
  ]; %>
  <% for (const [cat, anchor, tk, bk, col, bg, deep] of groups) { %>
  <section id="<%= anchor %>" style="padding:20px 0 28px">
    <div style="border-left:5px solid <%- col %>;padding-left:16px;margin-bottom:20px">
      <span class="cc-tag" style="background:<%- bg %>;color:<%- deep %>;margin:0"><%= cat === 'heatpump' ? ct('home.cat_hp_tag') : ct('home.cat_ac_tag') %></span>
      <h2 style="font-size:30px;margin:10px 0 6px"><%- ct(tk) %></h2>
      <p style="margin:0;color:var(--color-neutral-700);max-width:70ch"><%- ct(bk) %></p>
    </div>
    <div class="svc-grid">
      <% for (const p of products.filter(x => x.category === cat)) { %>
      <a class="svc-card" href="<%= link('/prodotti') %>/<%= p.slug %>" data-track="cta_click" data-track-meta="product_<%= p.slug %>">
        <span style="display:flex;justify-content:space-between;align-items:center">
          <span class="eei<%- p.efficiency === 'A++' ? ' e2' : '' %>"><%= p.efficiency %></span>
          <span style="font-size:11px;color:var(--color-neutral-500)"><%= p.slug.toUpperCase() %></span>
        </span>
        <h4><%= EN && p.name_en ? p.name_en : p.name_it %></h4>
        <p><%= EN && p.desc_en ? p.desc_en : p.desc_it %></p>
        <span class="tc-go" style="display:inline-block;margin-top:10px;font-size:13.5px"><%- ct('ui.read_more') %></span>
      </a>
      <% } %>
    </div>
  </section>
  <% } %>

  <section class="band-dark" style="border-radius:var(--radius-lg);padding:32px;margin:24px 0 64px">
    <p style="margin:0;font-size:15px;max-width:70ch"><%- ct('prodotti.note') %></p>
    <a class="btn btn-primary" href="<%= link('/login') %>" style="text-decoration:none;margin-top:18px"><%- ct('ui.area_riservata') %> →</a>
  </section>

  <%- include('partials/footer') %>
</div>
<%- include('partials/tail') %>
