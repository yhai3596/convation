<%- include('partials/head') %>
<%- include('partials/nav') %>

<% const EN = (typeof locale !== 'undefined' && locale === 'en'); %>
<div class="container" style="padding-top:20px;padding-bottom:40px">
  <div style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:14px">
    <div>
      <span class="card-kicker"><a href="<%= link('/strumenti') %>" style="color:inherit;text-decoration:none"><%= EN ? 'HVAC tools' : 'Strumenti HVAC' %></a></span>
      <h1 style="font-size:26px;margin:6px 0 0"><%= t.name %></h1>
      <p style="margin:6px 0 0;font-size:13.5px;color:var(--color-neutral-600);max-width:70ch"><%= t.description %></p>
    </div>
    <a class="btn btn-secondary" href="<%= t.url %>" target="_blank" rel="noopener" style="text-decoration:none;font-size:13px">↗ <%= EN ? 'Open in new tab' : 'Apri in nuova scheda' %></a>
  </div>
  <div style="position:relative">
    <iframe src="<%= t.url %>" title="<%= t.name %>" class="tool-frame" style="width:100%;min-height:70vh;border:1px solid var(--color-divider);border-radius:var(--radius-md);background:#fff" loading="lazy" referrerpolicy="no-referrer"></iframe>
  </div>
  <p style="font-size:12px;color:var(--color-neutral-500);margin-top:12px">ⓘ <%= EN ? 'Tool embedded from hvac.geopro.cc (English interface). ' : 'Strumento incorporato da hvac.geopro.cc (interfaccia in inglese). ' %><%- ct('strumenti.lang_note') %></p>
</div>
<%- include('partials/footer') %>
<%- include('partials/tail') %>
