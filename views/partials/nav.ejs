<div class="topbar">
  <div class="topbar-inner">
    <div class="tb-group">
      <span>☎ <%- ct('site.phone') %></span>
      <a href="mailto:<%- ct('site.email_info') %>"><%- ct('site.email_info') %></a>
      <a href="/detrazioni">Detrazioni e incentivi</a>
    </div>
    <div class="tb-group">
      <a href="/login"><%- ct('ui.area_riservata') %> →</a>
    </div>
  </div>
</div>
<nav class="nav site-nav">
  <a href="/" class="nav-brand" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:10px">
    <img src="/assets/logo.jpg" alt="Convation" style="height:34px;width:auto;display:block">
  </a>
  <% const navItems = [['Prodotti','/prodotti','prodotti'],['Documentazione','/documentazione','documentazione'],['Strumenti','/strumenti','strumenti'],['Referenze','/referenze','referenze'],['Assistenza','/assistenza','assistenza'],['Chi siamo','/chi-siamo','chi-siamo']]; %>
  <% for (const [label, href, key] of navItems) { %>
  <a href="<%= href %>"<%- active === key ? ' aria-current="page"' : '' %>><%= label %></a>
  <% } %>
  <% if (user) { %>
  <span style="font-size:13px;color:var(--color-neutral-600);white-space:nowrap">Ciao, <%= user.name %></span>
  <% if (user.role === 'admin') { %><a href="/admin" style="font-size:13px">Admin</a><% } %>
  <a href="#" id="nav-logout" style="font-size:13px">Esci</a>
  <% } else { %>
  <a class="btn btn-primary" href="/consulenza" style="text-decoration:none">Richiedi preventivo</a>
  <% } %>
</nav>
