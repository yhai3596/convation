<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'it' %>">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= title %></title>
<meta name="description" content="<%= (typeof locale !== 'undefined' && locale === 'en') ? 'Convation — sale, installation and service of heat pumps and air conditioners in Italy. A reliable partner for installers and homeowners.' : 'Convation — vendita, installazione e assistenza di pompe di calore e climatizzatori in Italia. Partner affidabile per installatori e privati.' %>">
<% if (typeof hrefIt !== 'undefined') { %>
<link rel="canonical" href="<%= (typeof locale !== 'undefined' && locale === 'en') ? hrefEn : hrefIt %>">
<link rel="alternate" hreflang="it" href="<%= hrefIt %>">
<link rel="alternate" hreflang="en" href="<%= hrefEn %>">
<link rel="alternate" hreflang="x-default" href="<%= hrefIt %>">
<% } %>
<link rel="icon" type="image/png" href="/assets/logo.png">
<link rel="stylesheet" href="/vendor/archivo/500.css">
<link rel="stylesheet" href="/vendor/archivo/600.css">
<link rel="stylesheet" href="/vendor/archivo/700.css">
<link rel="stylesheet" href="/vendor/inter/400.css">
<link rel="stylesheet" href="/vendor/inter/600.css">
<link rel="stylesheet" href="/vendor/inter/700.css">
<link rel="stylesheet" href="/css/ds.css?v=<%= assetVer %>">
<link rel="stylesheet" href="/css/site.css?v=<%= assetVer %>">
<script src="/js/theme.js?v=<%= assetVer %>"></script>
</head>
<body>
