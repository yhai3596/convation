<!-- Assistente clienti AI Convation（全站悬浮，人工可接管） -->
<% const AEN = (typeof locale !== 'undefined' && locale === 'en'); %>
<div id="assistant-root" style="position:fixed;right:24px;bottom:24px;z-index:60;display:flex;flex-direction:column;align-items:flex-end;gap:13.8px;font-family:'Inter',sans-serif">
  <div id="assistant-panel" class="elev-lg" hidden style="width:min(340px,calc(100vw - 48px));display:flex;flex-direction:column;background:var(--color-bg);border:1px solid var(--color-divider);border-radius:var(--radius-lg);overflow:hidden">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:13.8px;padding:13.8px 18px;border-bottom:1px solid var(--color-divider)">
      <div style="display:flex;flex-direction:column;gap:2px">
        <span style="font-family:'Archivo',sans-serif;font-weight:600;font-size:16px"><%= AEN ? 'Convation Assistant' : 'Assistente Convation' %></span>
        <span style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-neutral-600)"><%= AEN ? 'AI · human handover available' : 'AI · operatore umano disponibile' %></span>
      </div>
      <button type="button" id="assistant-close" class="btn btn-icon btn-secondary" aria-label="<%= AEN ? 'Close' : 'Chiudi' %>">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
      </button>
    </div>
    <div id="assistant-msgs" style="display:flex;flex-direction:column;gap:13.8px;padding:18px;max-height:280px;overflow-y:auto"></div>
    <div style="display:flex;flex-wrap:wrap;gap:9.2px;padding:0 18px 13.8px">
      <button type="button" class="tag tag-outline" data-quick="<%= AEN ? 'How does the Conto Termico work?' : 'Come funziona il Conto Termico?' %>" style="cursor:pointer;background:transparent"><%= AEN ? 'Conto Termico' : 'Conto Termico' %></button>
      <button type="button" class="tag tag-outline" data-quick="<%= AEN ? 'What does the warranty cover?' : 'Quanto costa una pompa di calore?' %>" style="cursor:pointer;background:transparent"><%= AEN ? 'Warranty' : 'Preventivo' %></button>
      <button type="button" class="tag tag-outline" data-quick="<%= AEN ? 'Do you ship spare parts?' : 'Fate assistenza fuori zona?' %>" style="cursor:pointer;background:transparent"><%= AEN ? 'Service' : 'Assistenza' %></button>
    </div>
    <div style="display:flex;gap:9.2px;padding:13.8px 18px;border-top:1px solid var(--color-divider)">
      <input class="input" id="assistant-input" type="text" placeholder="<%= AEN ? 'Ask your question…' : 'Scrivi la tua domanda…' %>" style="flex:1">
      <button type="button" id="assistant-send" class="btn btn-primary"><%= AEN ? 'Send' : 'Invia' %></button>
    </div>
  </div>
  <button type="button" id="assistant-fab" class="elev-md" aria-label="<%= AEN ? 'Open assistant' : 'Apri assistente' %>" style="width:54px;height:54px;border-radius:50%;cursor:pointer;display:grid;place-items:center;background:var(--color-accent);border:none;color:#fff">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
  </button>
</div>
