<%- include('partials/head') %>
<%- include('partials/nav') %>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"HVACBusiness","name":"Convation S.r.l.","url":"https://www.convation.it","telephone":"<%- ct('site.phone') %>","email":"<%- ct('site.email_info') %>","address":{"@type":"PostalAddress","streetAddress":"<%- ct('site.address') %>","addressCountry":"IT"},"areaServed":"IT","knowsAbout":["pompe di calore","climatizzatori","installazione","assistenza","Conto Termico"]}
</script>

<div class="container">

  <section class="grid-hero" style="padding:72px 0 48px">
    <div>
      <span class="kicker"><%- ct('home.kicker') %></span>
      <h1 style="font-size:clamp(36px,4.6vw,56px);margin:0"><%- ctBr('home.hero_title') %></h1>
      <p style="font-size:17px;max-width:58ch;margin:26px 0 0;color:color-mix(in srgb, var(--color-text) 85%, transparent)"><%- ct('home.hero_body') %></p>

      <div class="track-grid">
        <a class="track-card" href="<%= link('/consulenza') %>" data-track="cta_click" data-track-meta="track_privato">
          <span class="tc-kicker"><%- ct('home.track_p_kicker') %></span>
          <h3><%- ct('home.track_p_title') %></h3>
          <p><%- ct('home.track_p_body') %></p>
          <span class="tc-go"><%- ct('ui.read_more') %></span>
        </a>
        <a class="track-card" href="<%= link('/login') %>" data-track="cta_click" data-track-meta="track_installatore">
          <span class="tc-kicker"><%- ct('home.track_i_kicker') %></span>
          <h3><%- ct('home.track_i_title') %></h3>
          <p><%- ct('home.track_i_body') %></p>
          <span class="tc-go"><%- ct('ui.read_more') %></span>
        </a>
      </div>
    </div>
  </section>

  <div class="trustbar">
    <% for (let i = 1; i <= 4; i++) { %>
    <span class="tb-item"><b><%- ct('home.trust' + i + '_value') %></b> <%- ct('home.trust' + i + '_label') %></span>
    <% } %>
  </div>

  <section style="padding:64px 0">
    <span class="kicker"><%- ct('home.cats_kicker') %></span>
    <div class="cat-grid">
      <a class="cat-card" href="<%= link('/prodotti') %>#pompe-di-calore" style="--cat-color:var(--color-accent-2-500);--cat-bg:var(--color-accent-2-100);--cat-deep:var(--color-accent-2-800)" data-track="cta_click" data-track-meta="cat_hp">
        <span class="cc-tag"><%- ct('home.cat_hp_tag') %></span>
        <h3><%- ct('home.cat_hp_title') %></h3>
        <p><%- ct('home.cat_hp_body') %></p>
      </a>
      <a class="cat-card" href="<%= link('/prodotti') %>#climatizzatori" style="--cat-color:var(--color-cool-500);--cat-bg:var(--color-cool-100);--cat-deep:var(--color-cool-800)" data-track="cta_click" data-track-meta="cat_ac">
        <span class="cc-tag"><%- ct('home.cat_ac_tag') %></span>
        <h3><%- ct('home.cat_ac_title') %></h3>
        <p><%- ct('home.cat_ac_body') %></p>
      </a>
    </div>
  </section>

  <section style="padding:24px 0 64px">
    <span class="kicker"><%- ct('home.svc_kicker') %></span>
    <div class="svc-grid">
      <a class="svc-card" href="<%= link('/documentazione') %>">
        <span class="card-kicker">01</span>
        <h4><%- ct('home.svc1_title') %></h4>
        <p><%- ct('home.svc1_body') %></p>
      </a>
      <a class="svc-card" href="<%= link('/login') %>">
        <span class="card-kicker">02</span>
        <h4><%- ct('home.svc2_title') %></h4>
        <p><%- ct('home.svc2_body') %></p>
      </a>
      <a class="svc-card" href="<%= link('/strumenti') %>">
        <span class="card-kicker">03</span>
        <h4><%- ct('home.svc3_title') %></h4>
        <p><%- ct('home.svc3_body') %></p>
      </a>
    </div>
  </section>

</div>

<section class="band-dark">
  <div class="container" style="padding:56px 0">
    <span class="kicker"><%- ct('home.detr_kicker') %></span>
    <h2 style="font-size:clamp(26px,3vw,36px);max-width:22ch;margin:0"><%- ct('home.detr_title') %></h2>
    <p style="max-width:60ch;margin:18px 0 0;color:#B9C7D6"><%- ct('home.detr_body') %></p>
    <a class="btn btn-primary" href="<%= link('/detrazioni') %>" style="text-decoration:none;margin-top:24px"><%- ct('ui.read_more') %></a>
  </div>
</section>

<div class="container">
  <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
  <section style="padding:56px 0 8px">
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;flex-wrap:wrap">
      <span class="kicker" style="margin-bottom:0">News</span>
      <a href="<%= link('/news') %>" style="font-size:14px"><%= (typeof locale !== 'undefined' && locale === 'en') ? 'All articles →' : 'Tutti gli articoli →' %></a>
    </div>
    <div class="grid-cards3" style="margin-top:22px">
      <% for (const p of posts) { %>
      <a href="<%= link('/news') %>/<%= p.slug %>" class="card" style="text-decoration:none;color:inherit;padding:20px;background:#fff">
        <span class="card-kicker" style="font-feature-settings:'tnum' 1"><%= fmtDate(p.published_at) %> · <%= p.category %></span>
        <span class="card-title" style="font-size:17px"><%= p.title %></span>
        <span class="card-body"><%= p.excerpt %></span>
      </a>
      <% } %>
    </div>
  </section>
  <% } %>

  <section style="padding:64px 0 72px;text-align:center">
    <h2 style="font-size:clamp(26px,3vw,34px);margin:0 auto;max-width:24ch"><%- ct('home.cta_title') %></h2>
    <p style="max-width:56ch;margin:18px auto 0;color:var(--color-neutral-700)"><%- ct('home.cta_body') %></p>
    <div style="display:flex;gap:14px;justify-content:center;margin-top:28px;flex-wrap:wrap">
      <a class="btn btn-primary" href="<%= link('/consulenza') %>" style="text-decoration:none" data-track="cta_click" data-track-meta="home_cta">Richiedi preventivo gratuito</a>
      <a class="btn btn-secondary" href="<%= link('/contatti') %>" style="text-decoration:none"><%- ct('contatti.hero_title') %></a>
    </div>
  </section>

  <%- include('partials/footer') %>
</div>

<%- include('partials/tail') %>
