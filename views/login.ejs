<%- include('partials/head') %>

<div style="min-height:100vh;display:grid;place-items:center;padding:42px 20px;box-sizing:border-box">
  <div style="width:min(400px,100%)">
    <a href="/" style="text-decoration:none;color:inherit;display:flex;justify-content:center;margin-bottom:12px">
      <img src="/assets/logo.png" alt="Convation" style="height:56px;width:auto">
    </a>
    <p style="text-align:center;font-size:13px;color:var(--color-neutral-600);margin:0 0 28px">Area Riservata · installatori e clienti registrati</p>

    <div class="card" style="padding:36px">
      <div style="display:flex;margin-bottom:28px">
        <button type="button" id="tab-login" style="all:unset;box-sizing:border-box;cursor:pointer;flex:1;text-align:center;padding:9px 0;font-size:14px;border-bottom:2px solid var(--color-accent);color:var(--color-accent-700)">Accedi</button>
        <button type="button" id="tab-reg" style="all:unset;box-sizing:border-box;cursor:pointer;flex:1;text-align:center;padding:9px 0;font-size:14px;border-bottom:2px solid transparent;color:var(--color-text)">Registrati</button>
      </div>

      <form id="form-login" style="display:flex;flex-direction:column;gap:20px">
        <div class="field"><label>Email</label><input class="input" type="email" id="login-email" placeholder="nome@esempio.it" autocomplete="email"></div>
        <div class="field"><label>Password</label><input class="input" type="password" id="login-password" placeholder="••••••••" autocomplete="current-password"></div>
        <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" checked>Ricordami</label>
          <a href="#" id="forgot-link">Password dimenticata?</a>
        </div>
        <p class="form-error" id="login-error"></p>
        <button type="submit" class="btn btn-primary btn-block">Accedi</button>
      </form>

      <form id="form-reg" hidden style="display:flex;flex-direction:column;gap:20px">
        <div class="field"><label>Nome e cognome</label><input class="input" type="text" id="reg-name" placeholder="Mario Rossi" autocomplete="name"></div>
        <div class="field"><label>Email</label><input class="input" type="email" id="reg-email" placeholder="nome@esempio.it" autocomplete="email"></div>
        <div class="field"><label>Password</label><input class="input" type="password" id="reg-password" placeholder="Almeno 8 caratteri" autocomplete="new-password"></div>
        <label style="display:flex;align-items:flex-start;gap:8px;font-size:12.5px;line-height:20px;color:var(--color-neutral-600);cursor:pointer"><input type="checkbox" id="reg-agree" style="margin-top:3px">Accetto i termini di servizio e l’informativa privacy. Gli account installatore vengono attivati dopo verifica.</label>
        <p class="form-error" id="reg-error"></p>
        <button type="submit" class="btn btn-primary btn-block">Crea account</button>
      </form>

      <p style="font-size:12.5px;color:var(--color-neutral-600);margin:22px 0 0;text-align:center">Sei un installatore e non hai ancora un account? <a href="/contatti">Richiedi l’attivazione</a></p>
    </div>

    <p style="text-align:center;font-size:13px;color:var(--color-neutral-600);margin-top:28px"><a href="/">← Torna alla home</a></p>
  </div>
</div>

<script>
(function () {
  var NEXT = <%- JSON.stringify(next) %>;
  var tabLogin = document.getElementById('tab-login');
  var tabReg = document.getElementById('tab-reg');
  var formLogin = document.getElementById('form-login');
  var formReg = document.getElementById('form-reg');

  function setTab(mode) {
    var isLogin = mode === 'login';
    formLogin.hidden = !isLogin;
    formReg.hidden = isLogin;
    tabLogin.style.borderBottomColor = isLogin ? 'var(--color-accent)' : 'transparent';
    tabLogin.style.color = isLogin ? 'var(--color-accent-700)' : 'var(--color-text)';
    tabReg.style.borderBottomColor = !isLogin ? 'var(--color-accent)' : 'transparent';
    tabReg.style.color = !isLogin ? 'var(--color-accent-700)' : 'var(--color-text)';
  }
  tabLogin.addEventListener('click', function () { setTab('login'); });
  tabReg.addEventListener('click', function () { setTab('reg'); });

  function post(url, data, errEl) {
    errEl.textContent = '';
    return fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) })
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
      .then(function (res) {
        if (!res.ok) { errEl.textContent = res.d.error || 'Operazione non riuscita, riprova'; return null; }
        return res.d;
      })
      .catch(function () { errEl.textContent = 'Errore di rete, riprova'; return null; });
  }
  function sid() { return window.AlanTrack ? AlanTrack.sid : ''; }

  formLogin.addEventListener('submit', function (e) {
    e.preventDefault();
    post('/api/auth/login', {
      email: document.getElementById('login-email').value,
      password: document.getElementById('login-password').value,
      sid: sid()
    }, document.getElementById('login-error')).then(function (d) {
      if (d) location.href = d.user && d.user.role === 'admin' && NEXT === '/' ? '/admin' : NEXT;
    });
  });

  formReg.addEventListener('submit', function (e) {
    e.preventDefault();
    post('/api/auth/register', {
      name: document.getElementById('reg-name').value,
      email: document.getElementById('reg-email').value,
      password: document.getElementById('reg-password').value,
      agree: document.getElementById('reg-agree').checked,
      sid: sid()
    }, document.getElementById('reg-error')).then(function (d) {
      if (d) location.href = NEXT;
    });
  });

  document.getElementById('forgot-link').addEventListener('click', function (e) {
    e.preventDefault();
    alanToast('Per reimpostare la password scrivi a assistenza@convation.it indicando la tua email di registrazione.');
  });
})();
</script>
<%- include('partials/tail', { noAssistant: true }) %>
